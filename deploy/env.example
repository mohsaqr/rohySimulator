# /etc/rohy/env — production environment file for the rohy systemd unit.
#
# Copy to /etc/rohy/env (or wherever your unit's EnvironmentFile= points),
# fill in the marked values, and `chmod 600` it (root:root). Do NOT commit
# a filled-in copy back to git — this file is the secret-bearing canonical.
#
# Every variable is documented inline. The "fatal/required/optional" tag
# matches what server/config/validateEnv.js enforces at boot.

# === Fatal — server refuses to start without this ===

# JWT_SECRET — signs every auth token. Must be a long random string.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# === Required in production ===

# NODE_ENV — must be 'production' on a deployed server. Disables seeders,
# dev helpers, and request-body verbosity.
NODE_ENV=production

# FRONTEND_URL — the public URL browsers will use to reach this rohy
# install. Add it to the CORS allowlist. Without this, browser asset loads
# silently 500 with `[CORS] Blocked request from origin:` in journal.
# Examples:
#   https://example.com/rohy        ← public deploy behind nginx + cert
#   https://192.168.50.39:4001/rohy ← LAN deploy with self-signed cert
FRONTEND_URL=https://your-deploy-host/rohy

# === Strongly recommended in production ===

# ROHY_DB — absolute path to the SQLite database. Putting it OUTSIDE the
# repo means `npm ci`, fresh clones, and rsync deploys can't wipe it.
# Pre-create the parent dir with `mkdir -p` and `chown` it to the user
# the rohy.service runs as.
ROHY_DB=/opt/data/rohy/database.sqlite

# TRANSFORMERS_CACHE — where @huggingface/transformers caches the Kokoro
# model (~330 MB). The default is inside node_modules/, which is wiped by
# every `npm ci`. After the wipe, the model re-downloads — and a network
# blip during re-download produces a truncated .onnx that crashes the
# Node process via ONNX Runtime. See AGENT-NOTE-DEPLOY-2026-05-07.md §4
# for the full incident. Pre-create this dir with the runtime user's
# ownership.
TRANSFORMERS_CACHE=/var/cache/rohy-hf

# === Optional ports ===

# PORT — HTTP listener (the one nginx forwards to). Default 3000.
PORT=4000

# HTTPS_PORT — direct HTTPS listener for getUserMedia on private LAN
# without nginx. Defaults to PORT+1000. Only used if TLS_CERT_PATH +
# TLS_KEY_PATH are also set.
# HTTPS_PORT=5000

# TLS_CERT_PATH / TLS_KEY_PATH — PEM files for the optional HTTPS listener.
# Skip if nginx is terminating TLS in front of rohy. If set, both must be
# set (validateEnv enforces this).
# TLS_CERT_PATH=/etc/letsencrypt/live/your-host/fullchain.pem
# TLS_KEY_PATH=/etc/letsencrypt/live/your-host/privkey.pem

# === Add-ons ===

# OYON_ENABLED — gates the local-browser emotion capture add-on (face
# landmarks via MediaPipe + emotion classification via EmotiEffLib ONNX
# models, all inference client-side; only aggregate windows reach the
# server). Default install paths set this to 1 because they also fetch
# the binary bundles via OyonR/scripts/download-models.sh; turning it
# off here will not save space — only the routes are gated. Without
# this var, Settings → Oyon tabs show a "disabled" panel with the same
# message that printed at install time, NOT a generic 404.
OYON_ENABLED=1

# === Knobs you usually leave alone ===

# ROHY_TRUST_PROXY — Express trust-proxy setting. Default 'loopback' is
# right when nginx runs on the same host. Use 'uniquelocal' if you have
# multiple proxies in the chain, an integer hop-count, or a CIDR.
# ROHY_TRUST_PROXY=loopback

# ROHY_SHUTDOWN_GRACE_MS — how long graceful shutdown waits for in-flight
# requests after SIGTERM. systemd's TimeoutStopSec defaults to 90s, so
# anything below that is safe. 15s is plenty for normal traffic.
# ROHY_SHUTDOWN_GRACE_MS=15000

# ROHY_ROUTE_TIMEOUT_MS — per-request timeout (excludes /tts and /proxy/llm,
# which stream). Default 30000. A handler that hangs longer than this
# returns 504 ROUTE_TIMEOUT to the client instead of a generic nginx 502.
# ROHY_ROUTE_TIMEOUT_MS=30000

# ROHY_BACKUP_BEFORE_MIGRATE — set to 0 to skip the auto-backup that
# server/db.js performs before applying pending migrations. Default is
# enabled. Skip only if disk space is tight; backup failure is non-fatal
# anyway.
# ROHY_BACKUP_BEFORE_MIGRATE=1

# ROHY_NO_AUTO_SEED — set to 1 to suppress first-boot seeding inside the
# request-serving process. Run `node scripts/seed.js` separately when
# needed. Useful in production to keep the request path lean.
# ROHY_NO_AUTO_SEED=1

# === Bootstrap-only, REMOVE after first successful login ===

# ALLOW_DEFAULT_USERS — gates the default-user seeder in production.
# Without this, you boot to an empty users table and can't log in. Set to
# 1 for the FIRST boot, log in as admin/admin123, change the password,
# THEN delete this line and `systemctl restart rohy`.
# ALLOW_DEFAULT_USERS=1
