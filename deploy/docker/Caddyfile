# deploy/docker/Caddyfile — Caddy 2 config for rohy.
#
# TLS: this file is INTERNAL-ONLY (Caddy's internal CA, self-signed certs).
# Earlier revisions advertised env-driven auto/internal/off selection via
# ROHY_TLS_MODE, but Caddyfiles can't conditionally include directives, and
# the file ended up always emitting `tls internal` regardless of the env —
# so the docs lied. Made honest now: this file is one mode, switching is a
# manual edit (instructions at the bottom of the file).
#
# Streaming TTS:
#   The /api/tts route streams audio chunks. Caddy's reverse_proxy flushes
#   on every chunk by default for non-buffered transports, but binary
#   streams need an explicit `flush_interval -1` in some Caddy versions.
#   Hardcoded below so it doesn't regress.
#
# Subpath:
#   rohy is built with `vite build --base=/rohy/`, so the SPA expects to
#   live at /rohy/. The reverse_proxy strip_prefix below makes this work.

{
    # Caddy global options. Email is for Let's Encrypt account; only used
    # in `auto` mode. Operators with the env unset still get a working
    # Caddy in `internal`/`off` mode.
    email {$ACME_EMAIL:admin@example.com}

    # Auto-HTTPS is on by default, which is right for `auto` and `internal`
    # modes. For `off` mode (plain HTTP), add `auto_https off` here AND
    # prefix the site block below with `http://`.
}

# === Site block ===========================================================
{$ROHY_HOSTNAME:localhost} {
    # Internal CA, self-signed cert. Browsers will warn until you trust the
    # Caddy root CA on the client. To extract and trust it:
    #   docker exec rohy-caddy cat /data/caddy/pki/authorities/local/root.crt
    # then add the resulting PEM to your OS keychain.
    tls internal

    # Compression — Caddy auto-negotiates. Disable on /api/tts so audio
    # frames don't get re-encoded mid-stream.
    encode {
        zstd
        gzip 5
    }

    # Security headers. The Express layer also sets some of these; doubling
    # up at the proxy is cheap and survives backend swaps.
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        # HSTS only if TLS is real (auto). Leave commented otherwise so
        # browsers don't pin to HTTPS for a localhost dev box.
        # Strict-Transport-Security "max-age=31536000; includeSubDomains"
    }

    # Body size — clinical record uploads can include images. 50 MB matches
    # the multer cap inside rohy.
    request_body {
        max_size 50MB
    }

    # === Streaming TTS — DO NOT BUFFER ====================================
    # The order matters: this matcher block has to come before the catch-all
    # /rohy/* reverse_proxy so it wins the route.
    handle /rohy/api/tts* {
        uri strip_prefix /rohy
        reverse_proxy rohy:4000 {
            # flush_interval -1 = flush on every Write (true streaming).
            flush_interval -1
            transport http {
                # Disable response buffering for chunked binary audio.
                response_header_timeout 300s
                read_timeout 300s
            }
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # === Health probes — bypass auth/rate-limit blocks =================
    handle /rohy/api/health {
        reverse_proxy rohy:4000 {
            rewrite /api/health
        }
    }
    handle /rohy/api/ready {
        reverse_proxy rohy:4000 {
            rewrite /api/ready
        }
    }

    # === Oyon root-absolute paths =======================================
    # The Oyon widget and the vendored standalone HTML use root-absolute
    # URLs like /oyon/standalone/logs.html, /standalone/vendor/onnxruntime-web/,
    # and /api/addons/oyon/* — they don't honour the SPA's /rohy/ base.
    # Making the client base-aware would touch model/wasm fetch URLs, the
    # standalone's importmap, and every "Open Oyon" launcher in the SPA;
    # proxying these prefixes through to the same Express upstream is far
    # less invasive and keeps the privacy contract identical (still local
    # browser inference, still aggregate windows).
    handle /oyon/* {
        reverse_proxy rohy:4000 {
            transport http {
                response_header_timeout 300s
                read_timeout 300s
                dial_timeout 10s
            }
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }
    handle /standalone/* {
        reverse_proxy rohy:4000 {
            transport http {
                response_header_timeout 300s
                read_timeout 300s
                dial_timeout 10s
            }
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }
    handle /api/addons/oyon* {
        reverse_proxy rohy:4000 {
            transport http {
                response_header_timeout 300s
                read_timeout 300s
                dial_timeout 10s
            }
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    # === Everything else under /rohy ======================================
    handle_path /rohy/* {
        reverse_proxy rohy:4000 {
            transport http {
                response_header_timeout 300s
                read_timeout 300s
                dial_timeout 10s
            }
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    # If the operator hits `/`, redirect to /rohy/ for the SPA. Skip this
    # if you serve other apps from the same hostname.
    handle / {
        redir /rohy/ 302
    }
}

# === How to switch TLS mode (manual edits) ================================
#
# Default (above) is INTERNAL CA, suitable for LAN/dev. Two other modes:
#
# 1) Let's Encrypt (`auto`):
#    - Replace the line `tls internal` with no `tls` directive at all.
#    - Set ACME_EMAIL in your environment (already templated above).
#    - Make sure ROHY_HOSTNAME is a real public hostname, not localhost.
#    - Open ports 80 + 443 from the public internet to this container.
#
# 2) Plain HTTP (`off`) — localhost / behind another TLS terminator only:
#    - Add `auto_https off` to the global block at the top of this file.
#    - Replace `tls internal` with `# tls off (no directive needed)`.
#    - Prefix the site block with `http://` so Caddy doesn't auto-upgrade:
#        http://{$ROHY_HOSTNAME:localhost} { ... }
#    - getUserMedia (mic) DOES NOT work on plain HTTP from non-localhost
#      origins, so this mode is useful only behind a real TLS terminator.
