# deploy/docker/.env — runtime config for `docker compose`.
#
# Copy this to .env in the same directory and edit the values you care
# about. Compose reads .env automatically; nothing else looks at it.
#
# DO NOT commit a filled-in .env back to git. The example file is safe
# (only placeholders); the real .env can hold secrets.

# === Required ============================================================

# The hostname browsers use to reach rohy. Examples:
#   ROHY_HOSTNAME=rohy.example.com    # public deploy + Let's Encrypt
#   ROHY_HOSTNAME=192.168.1.42        # LAN deploy + internal CA
#   ROHY_HOSTNAME=localhost           # local dev box
ROHY_HOSTNAME=localhost

# TLS MODE — manual edit, NOT env-driven.
#
# The shipped Caddyfile uses `tls internal` (Caddy's self-signed CA),
# which is the right default for LAN / dev. To switch to Let's Encrypt
# (`auto`) or plain HTTP (`off`), edit deploy/docker/Caddyfile per the
# instructions at the bottom of that file, then re-run
# `docker compose -f deploy/docker/compose.yml up -d`.
#
# An earlier revision exposed this as ROHY_TLS_MODE=auto|internal|off
# but Caddyfile syntax cannot conditionally apply directives, so the
# variable was silently ignored and operators picking `auto` got a self-
# signed cert anyway. The variable was removed to stop the lie — see the
# header comment in Caddyfile for the full incident.

# === Optional ============================================================

# FRONTEND_URL is auto-derived as https://${ROHY_HOSTNAME}/rohy. Override
# only if your reverse proxy serves rohy at a different path.
# FRONTEND_URL=https://rohy.example.com/rohy

# Bind ports for Caddy. Default 80/443. Change if you already have something
# on those ports (e.g. another reverse proxy).
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443

# Bundle Piper TTS in the image (~150 MB extra). Defaults to off; Kokoro,
# Google, and OpenAI providers work without it. Admin can switch the active
# provider in Settings after first login.
# INCLUDE_PIPER=1

# Pin the dynajs sibling repo to a specific commit/tag for reproducible
# builds. Default is main; pin in production.
# DYNAJS_GIT_REF=v0.1.0

# Local-browser emotion capture add-on (face landmarks + valence/arousal,
# all on-device). Defaults to ON to match the source-install path. The
# routes mount under /api/addons/oyon/* and the standalone analytics page
# at /oyon/standalone/. Set to 0 to opt out — admin sees a friendly
# disabled panel in Settings rather than 404s. The wasm/mjs bundles are
# always present in the image regardless of this flag (only the routes
# are gated), so toggling doesn't change image size.
# OYON_ENABLED=1

# Email Caddy uses to register with Let's Encrypt (auto mode only).
# ACME_EMAIL=ops@example.com

# === First-boot bootstrap (REMOVE after first login) =====================

# Set to 1 for the FIRST container start. Seeds admin/admin123 if the
# users table is empty. Log in, change the password, REMOVE this line,
# `docker compose up -d` to apply.
# ALLOW_DEFAULT_USERS=1

# === API keys (optional — admin can set them in-app instead) =============

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_TTS_API_KEY=AIza...

# === Advanced — only set if you know you need it =========================

# Manual JWT_SECRET. If unset, the entrypoint generates one and persists
# it in the rohy-db volume. Override only if you have an external secret
# manager and want to rotate centrally. MUST be ≥32 random bytes (base64).
# JWT_SECRET=...

# Trust-proxy setting for Express. Default 'loopback' is right when
# Caddy runs on the same Docker host. 'uniquelocal' for multi-hop chains.
# ROHY_TRUST_PROXY=loopback
