{
  "name": "rohy",
  "private": true,
  "version": "2.7.4",
  "description": "Virtual Patient Simulation Platform for Medical Education",
  "author": {
    "name": "Mohammed Saqr",
    "email": "mohammed.saqr@uef.fi",
    "url": "https://www.saqr.me"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "node --watch server/server.js",
    "oyon:update": "bash scripts/update-oyonr.sh",
    "setup:oyon": "bash OyonR/scripts/download-models.sh",
    "install:piper": "bash server/scripts/install-piper.sh",
    "postinstall": "bash OyonR/scripts/download-models.sh 2>/dev/null || echo '[oyon] model bundles not downloaded — run: npm run setup:oyon (needs curl + network)'",
    "production": "NODE_ENV=production node server/server.js",
    "build": "{ npm run docs:build || echo '[build] docs:build failed — continuing without the docs site'; } && vite build --base=/rohy/ && rm -rf frontend && mkdir -p frontend && cp -rf dist/. frontend/",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --reporter=default",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile.junit=test-results.junit.xml --coverage",
    "test:server": "vitest run --project=server",
    "test:client": "vitest run --project=client",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "bench": "NODE_OPTIONS='--max-old-space-size=4096' vitest bench --run",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:gen:cli": "node scripts/docs-gen/gen-cli.mjs",
    "docs:gen:api": "node scripts/docs-gen/gen-api.mjs",
    "docs:gen:data": "node scripts/docs-gen/gen-data.mjs",
    "docs:gen:config": "node scripts/docs-gen/gen-config.mjs",
    "docs:check": "bash scripts/docs-gen/check.sh",
    "i18n:extract": "node node_modules/i18next-parser/bin/cli.js",
    "i18n:check": "node node_modules/i18next-parser/bin/cli.js --fail-on-update",
    "i18n:pseudo": "node scripts/generate-pseudo-locale.mjs",
    "i18n:translate": "node scripts/translate-locales.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/core": "^3.27.3",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-text-align": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dompurify": "^3.4.11",
    "dotenv": "^17.2.3",
    "dynajs": "file:../dynajs",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "i18next": "^26.3.4",
    "i18next-icu": "^2.4.4",
    "jsonwebtoken": "^9.0.3",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.562.0",
    "marked": "^17.0.6",
    "multer": "^2.0.2",
    "oyon": "file:./OyonR",
    "papaparse": "^5.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "sqlite3": "^5.1.7",
    "three": "^0.184.0",
    "wawa-lipsync": "^0.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "i18next-parser": "^9.0.2",
    "jsdom": "^25.0.1",
    "msw": "^2.6.8",
    "postcss": "^8.5.6",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  }
}
