{
  "name": "oyon",
  "version": "2.2.0",
  "description": "Local facial-expression analytics for browser-based learning simulations. Camera-side inference with MediaPipe + ONNX Runtime Web; only aggregate windows leave the device. Runs standalone or attaches to a host app.",
  "type": "module",
  "sideEffects": [
    "./src/ui/EmotionCaptureElement.js",
    "./src/ui/GazeCalibrationOverlay.js",
    "./dist/oyon.umd.js",
    "./dist/oyon.umd.min.js"
  ],
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./types/index.d.ts",
  "unpkg": "./dist/oyon.umd.min.js",
  "jsdelivr": "./dist/oyon.umd.min.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./react": {
      "types": "./types/react.d.ts",
      "import": "./src/react/index.js",
      "default": "./src/react/index.js"
    },
    "./react/panel": {
      "types": "./types/react-panel.d.ts",
      "import": "./src/react/EmotionCapturePanel.js",
      "default": "./src/react/EmotionCapturePanel.js"
    },
    "./attach": {
      "types": "./types/attach.d.ts",
      "import": "./src/adapters/oyonAttach.js",
      "default": "./src/adapters/oyonAttach.js"
    },
    "./adapter": {
      "types": "./types/adapter.d.ts",
      "import": "./src/adapters/rohyAttach.js",
      "default": "./src/adapters/rohyAttach.js"
    },
    "./addon": {
      "types": "./types/addon.d.ts",
      "import": "./src/addon/RohyOyonAddon.js",
      "default": "./src/addon/RohyOyonAddon.js"
    },
    "./validation": {
      "types": "./types/validation.d.ts",
      "import": "./src/validation/validateEmotionPayload.js",
      "default": "./src/validation/validateEmotionPayload.js"
    },
    "./settings": {
      "types": "./types/settings.d.ts",
      "import": "./src/settings/OyonSettings.js",
      "default": "./src/settings/OyonSettings.js"
    },
    "./logging": {
      "types": "./types/logging.d.ts",
      "import": "./src/logging/OyonLogger.js",
      "default": "./src/logging/OyonLogger.js"
    },
    "./analytics": {
      "types": "./types/analytics.d.ts",
      "import": "./src/analytics/DynamicalFeatures.js",
      "default": "./src/analytics/DynamicalFeatures.js"
    },
    "./engagement": {
      "types": "./types/engagement.d.ts",
      "import": "./src/aggregation/EngagementAggregator.js",
      "default": "./src/aggregation/EngagementAggregator.js"
    },
    "./gaze": {
      "types": "./types/gaze.d.ts",
      "import": "./src/aggregation/GazeAggregator.js",
      "default": "./src/aggregation/GazeAggregator.js"
    },
    "./gaze/adapter": {
      "types": "./types/gaze.d.ts",
      "import": "./src/inference/WebEyeTrackAdapter.js",
      "default": "./src/inference/WebEyeTrackAdapter.js"
    },
    "./gaze/webgazer-adapter": {
      "types": "./types/gaze.d.ts",
      "import": "./src/inference/WebGazerAdapter.js",
      "default": "./src/inference/WebGazerAdapter.js"
    },
    "./gaze/mediapipe-adapter": {
      "types": "./types/gaze.d.ts",
      "import": "./src/inference/MediaPipeLandmarkGazeAdapter.js",
      "default": "./src/inference/MediaPipeLandmarkGazeAdapter.js"
    },
    "./gaze/factory": {
      "types": "./types/gaze.d.ts",
      "import": "./src/inference/GazeAdapterFactory.js",
      "default": "./src/inference/GazeAdapterFactory.js"
    },
    "./ui/gaze-calibration": {
      "types": "./types/gaze.d.ts",
      "import": "./src/ui/GazeCalibrationOverlay.js",
      "default": "./src/ui/GazeCalibrationOverlay.js"
    },
    "./ui/gaze-calibration-driver": {
      "types": "./types/gaze.d.ts",
      "import": "./src/ui/GazeCalibrationDriver.js",
      "default": "./src/ui/GazeCalibrationDriver.js"
    },
    "./react/gaze-calibration": {
      "types": "./types/gaze.d.ts",
      "import": "./src/react/GazeCalibrationPanel.js",
      "default": "./src/react/GazeCalibrationPanel.js"
    },
    "./storage": {
      "types": "./types/storage.d.ts",
      "import": "./src/storage/IndexedDbOyonStore.js",
      "default": "./src/storage/IndexedDbOyonStore.js"
    },
    "./bundle": {
      "types": "./types/index.d.ts",
      "import": "./dist/oyon.esm.js",
      "default": "./dist/oyon.esm.js"
    },
    "./app-element": {
      "import": "./standalone/app/dist-element/oyon-app.element.js",
      "default": "./standalone/app/dist-element/oyon-app.element.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "oyon": "./bin/oyon.js"
  },
  "files": [
    "src",
    "bin",
    "dist",
    "standalone/app/dist-element",
    "types",
    "scripts/download-models.sh",
    "scripts/README.md",
    "README.md",
    "INSTALL.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "start:https": "node scripts/ensure-localhost-cert.mjs && OYON_HTTPS=1 vite --host 127.0.0.1",
    "demo": "vite --host 127.0.0.1",
    "app": "npm --prefix standalone/app run dev",
    "app:build": "npm --prefix standalone/app run build",
    "app:build:element": "npm --prefix standalone/app run build:element",
    "app:typecheck": "npm --prefix standalone/app run typecheck",
    "build": "rollup -c rollup.config.mjs",
    "build:clean": "rm -rf dist && npm run build",
    "check": "find src standalone -name '*.js' -not -path '*/node_modules/*' -not -path '*/vendor/*' -print0 | xargs -0 -n1 node --check",
    "test": "node tests/aggregation.test.js && node tests/wasm-paths.test.js && node tests/face-tracker-output.test.js && node tests/eye-features.test.js && node tests/eye-smoother.test.js && node tests/engagement-aggregator.test.js && node tests/runtime-engagement.test.js && node tests/validation.test.js && node tests/local-transport.test.js && node tests/http-transport.test.js && node tests/fallback-transport.test.js && node tests/rohy-addon.test.js && node tests/oyon-attach.test.js && node tests/oyon-addon.test.js && node tests/settings.test.js && node tests/logging.test.js && node tests/metrics.test.js && node tests/dynamics.test.js && node tests/runtime-settings.test.js && node tests/transition-network.test.js && node tests/web-eye-track-adapter.test.js && node tests/webgazer-adapter.test.js && node tests/gaze-engine-switch.test.js && node tests/mediapipe-gaze-adapter.test.js && node tests/gaze-smoother.test.js && node tests/gaze-aggregator.test.js && node tests/runtime-gaze.test.js && node tests/runtime-mediapipe-gaze.test.js && node tests/gaze-calibration-overlay.test.js && node tests/standalone-preview-data.test.js && node tests/app-runtime-contracts.test.js && node tests/app-filter-windows.test.js && node tests/app-tna-pooling.test.js && node tests/app-embed-contracts.test.js && node tests/exports-map.test.js",
    "test:e2e": "playwright test",
    "test:all": "npm run check && npm test && npm run app:typecheck && npm run test:e2e",
    "download-models": "bash scripts/download-models.sh",
    "prepublishOnly": "npm run check && npm test && npm run build:clean && npm run app:build:element"
  },
  "peerDependencies": {
    "@mediapipe/tasks-vision": "^0.10.22",
    "onnxruntime-web": "^1.20.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.20.0",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "facial-expression",
    "affect",
    "fer",
    "mediapipe",
    "onnx",
    "browser",
    "education",
    "research",
    "learning-analytics"
  ],
  "author": "Mohammed Saqr",
  "license": "MIT",
  "homepage": "https://github.com/mohsaqr/Oyon#readme",
  "bugs": {
    "url": "https://github.com/mohsaqr/Oyon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohsaqr/Oyon.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "webeyetrack": "^0.0.2",
    "webgazer": "^3.5.3"
  }
}
